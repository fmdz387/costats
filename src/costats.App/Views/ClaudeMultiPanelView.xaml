<UserControl x:Class="costats.App.Views.ClaudeMultiPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:costats.App">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- Progress bar style -->
        <Style x:Key="MetricProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="7" />
            <Setter Property="Background" Value="{DynamicResource TrackBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border x:Name="PART_Track" CornerRadius="3.5" Background="{TemplateBinding Background}" />
                            <Border x:Name="PART_Indicator" CornerRadius="3.5" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}">
                                <Border.Width>
                                    <MultiBinding Converter="{x:Static local:ProgressWidthConverter.Instance}">
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Value" />
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Maximum" />
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="ActualWidth" />
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <!-- Summary bar -->
        <Border Padding="12,8" Margin="0,0,0,0" CornerRadius="6" Background="{DynamicResource SummaryBackgroundBrush}">
            <DockPanel>
                <TextBlock Text="{Binding UpdatedLabel}"
                           FontSize="10.5"
                           Foreground="{DynamicResource TextFaintBrush}"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding MulticcSummary}"
                           FontSize="11.5"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           AutomationProperties.Name="Multicc profile summary" />
            </DockPanel>
        </Border>

        <!-- Scrollable profile list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding ClaudeProfiles}" Focusable="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,0"
                                        AutomationProperties.Name="{Binding DisplayName}">
                                <!-- Profile separator -->
                                <Border Height="1" Margin="0,10,0,10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="Transparent" Offset="0" />
                                            <GradientStop Color="{DynamicResource DividerSoftColor}" Offset="0.1" />
                                            <GradientStop Color="{DynamicResource DividerSoftColor}" Offset="0.9" />
                                            <GradientStop Color="Transparent" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <!-- Profile header -->
                                <DockPanel Margin="0,0,0,8">
                                    <Border DockPanel.Dock="Right"
                                            CornerRadius="4"
                                            Padding="6,2"
                                            VerticalAlignment="Center"
                                            BorderBrush="{DynamicResource ClaudeAccent}"
                                            Background="{DynamicResource ClaudeChipBackgroundBrush}"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding PlanText}"
                                                   FontSize="9.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ClaudeChipTextBrush}" />
                                    </Border>

                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </DockPanel>

                                <!-- Session metric -->
                                <StackPanel Margin="0,0,0,8">
                                    <DockPanel>
                                        <TextBlock Text="Session"
                                                   FontSize="11"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   VerticalAlignment="Bottom" />
                                        <TextBlock Text="{Binding SessionPercentText}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SessionMetricTextBrush}"
                                                   DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" />
                                    </DockPanel>
                                    <DockPanel Margin="0,4,0,0">
                                        <TextBlock Text="{Binding SessionResetText}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextFaintBrush}"
                                                   DockPanel.Dock="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="100" />
                                        <ProgressBar Value="{Binding SessionProgress}"
                                                     Maximum="1"
                                                     Foreground="{StaticResource SessionAccent}"
                                                     Style="{StaticResource MetricProgressBar}"
                                                     VerticalAlignment="Center"
                                                     AutomationProperties.Name="{Binding SessionUsageLabel}" />
                                    </DockPanel>
                                </StackPanel>

                                <!-- Weekly metric -->
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock Text="Weekly"
                                                   FontSize="11"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   VerticalAlignment="Bottom" />
                                        <TextBlock Text="{Binding WeekPercentText}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource WeeklyMetricTextBrush}"
                                                   DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right" />
                                    </DockPanel>
                                    <DockPanel Margin="0,4,0,0">
                                        <TextBlock Text="{Binding WeekResetText}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextFaintBrush}"
                                                   DockPanel.Dock="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="100" />
                                        <ProgressBar Value="{Binding WeekProgress}"
                                                     Maximum="1"
                                                     Foreground="{StaticResource WeeklyAccent}"
                                                     Style="{StaticResource MetricProgressBar}"
                                                     VerticalAlignment="Center"
                                                     AutomationProperties.Name="{Binding WeekUsageLabel}" />
                                    </DockPanel>
                                </StackPanel>

                                <!-- Compact cost summary -->
                                <TextBlock Text="{Binding CompactCostText}"
                                           FontSize="10.5"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,6,0,0"
                                           Visibility="{Binding HasCompactCost, Converter={StaticResource BoolToVisibilityConverter}}" />

                                <!-- Extra usage summary -->
                                <TextBlock Text="{Binding ExtraUsageLabel}"
                                           FontSize="10.5"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"
                                           Visibility="{Binding HasExtraUsage, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Aggregate totals -->
                <StackPanel Visibility="{Binding HasMulticcTotals, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,6,0,4">
                    <!-- Totals separator -->
                    <Border Height="1" Margin="0,8,0,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="Transparent" Offset="0" />
                                <GradientStop Color="{DynamicResource DividerStrongColor}" Offset="0.1" />
                                <GradientStop Color="{DynamicResource DividerStrongColor}" Offset="0.9" />
                                <GradientStop Color="Transparent" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <TextBlock Text="All Profiles"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,8" />

                    <!-- Today totals -->
                    <DockPanel Margin="0,0,0,5">
                        <TextBlock Text="Today:"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   DockPanel.Dock="Left" />
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding MulticcTotalTodayCost}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource CostTodayAccentBrush}" />
                            <TextBlock Text="  ·  " FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Text="{Binding MulticcTotalTodayTokens}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text=" tokens"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                        </StackPanel>
                    </DockPanel>

                    <!-- Weekly totals -->
                    <DockPanel>
                        <TextBlock Text="This week:"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   DockPanel.Dock="Left" />
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding MulticcTotalWeekCost}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource CostMonthAccentBrush}" />
                            <TextBlock Text="  ·  " FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                            <TextBlock Text="{Binding MulticcTotalWeekTokens}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text=" tokens"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </StackPanel>
</UserControl>
